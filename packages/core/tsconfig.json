{
    "exclude": [
        "../../node_modules/**",
        "./dist"
    ],
    "compilerOptions": {
        "lib": ["ES2024"],
        "module": "CommonJS",
        "target": "ES6",
        "moduleResolution": "node",
        "typeRoots": [
            "./types.d.ts"
        ],
        "rootDir": "./",
        "baseUrl": "./",
        "outDir": "./dist",
        "declaration": true,
        "declarationDir": "./dist/types",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "noImplicitAny": true,
        "strictNullChecks": true
    },
}