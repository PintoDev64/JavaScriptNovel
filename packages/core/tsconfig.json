{
    "include": ["src/**/*.ts", "src/index.d.ts"],
    "compilerOptions": {
        "module": "ESNext",
        "target": "ES6",
        "moduleResolution": "node",
        "outDir": "./dist",
        "declaration": true,
        "declarationDir": "./dist/types",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true
    }
}