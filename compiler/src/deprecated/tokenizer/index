import { returnName } from "./helpers";

export default function Tokenizer(lenguajeContent: string, returned: boolean = false): LenguajeTokens | LenguajeTokens[] {
    let cursorPosition = 0;
    let tokens: LenguajeTokens[] = [];

    // Native
    const PARAMS_SEPARATOR = ",";
    const COMMENT_LINE = /^\s*\/\//;
    const SEMICOLON = ";";
    const OPEN_PARENTHESIS = "(";
    const CLOSE_PARENTHESIS = ")";
    const WHITESPACES = /\s/;
    const NUMBERS = /[0-9]/;
    const LETTERS = /[a-z]/i;
    const STRING = /"/;
    const SPACEBAR = /\s/

    // Native Lenguaje
    const VAR_DECLARATION = "var"
    const VAR_ALLOCATION = "="


    while (cursorPosition < lenguajeContent.length) {
        let character = lenguajeContent[cursorPosition];

        /* console.log({
            cursorPosition,
            letters: lenguajeContent.length
        }); */

        // Manejar comentarios de línea
        if (COMMENT_LINE.test(lenguajeContent.slice(cursorPosition))) {
            // Avanza el cursor hasta el final de la línea
            while (cursorPosition < lenguajeContent.length && character !== "\n") {
                cursorPosition++;
                character = lenguajeContent[cursorPosition];
            }
            cursorPosition++;
            continue; // Ignorar el comentario
        }

        // Procesar paréntesis
        if (character === OPEN_PARENTHESIS) {
            tokens.push({ type: "parenthesis", value: OPEN_PARENTHESIS });
            cursorPosition++;
            continue;
        }

        if (character === CLOSE_PARENTHESIS) {
            tokens.push({ type: "parenthesis", value: CLOSE_PARENTHESIS });
            cursorPosition++;
            continue;
        }

        // Procesar comas como separadores de parámetros
        if (character === PARAMS_SEPARATOR) {
            tokens.push({ type: "comma", value: PARAMS_SEPARATOR });
            cursorPosition++;
            continue;
        }

        // Procesar espacios en blanco
        if (WHITESPACES.test(character)) {
            cursorPosition++;
            continue;
        }
        
        // Procesar punto y coma
        if (character === SEMICOLON) {
            tokens.push({ type: "semicolon", value: SEMICOLON });
            cursorPosition++;
            continue;
        }
        
        // Procesar Iguales
        if (character === EQUALEVAL) {
            tokens.push({ type: "semicolon", value: SEMICOLON });
            cursorPosition++;
            continue;
        }

        // Procesar números
        if (NUMBERS.test(character)) {
            let stringNumbers = "";
            while (NUMBERS.test(character)) {
                stringNumbers += character;
                cursorPosition++;
                character = lenguajeContent[cursorPosition];
            }
            if (returned) {
                return { type: "number", value: stringNumbers }
            } else {
                tokens.push({ type: "number", value: stringNumbers });
                continue
            }
        }

        // Procesar nombres (identificadores)
        if (LETTERS.test(character)) {
            const { position, value } = returnName(cursorPosition, LETTERS, lenguajeContent[cursorPosition], lenguajeContent)
            cursorPosition = position;

            if (value === VAR_DECLARATION) {
                cursorPosition++;
                const { position, value: varName } = returnName(cursorPosition, LETTERS, lenguajeContent[cursorPosition], lenguajeContent)
                cursorPosition = position;

                cursorPosition++;
                while (SPACEBAR.test(lenguajeContent[cursorPosition])) {
                    cursorPosition++
                }

                if (lenguajeContent[cursorPosition] === VAR_ALLOCATION) {
                    cursorPosition++
                    
                    console.log(lenguajeContent.slice(cursorPosition, lenguajeContent.length));

                    const variableType = Tokenizer(lenguajeContent.slice(cursorPosition, lenguajeContent.length), true) as LenguajeToken
                    console.log(variableType);
                    tokens.push({
                        type: "global",
                        name: varName,
                        value: variableType
                    });
                    continue;
                } else {
                    throw new TypeError(`the varaiable "${varName}" is not defined`);
                }

            }

            if (returned) {
                return { type: "name", value: value }
            } else {
                tokens.push({ type: "name", value: value });
                continue;
            }
        }

        // Procesar cadenas
        if (STRING.test(character)) {
            let textString = '';
            cursorPosition++;
            character = lenguajeContent[cursorPosition];

            while (cursorPosition < lenguajeContent.length) {
                if (character === '\\' && lenguajeContent[cursorPosition + 1] === '"') {
                    textString += '"';
                    cursorPosition += 2;
                    character = lenguajeContent[cursorPosition];
                    continue;
                }

                if (STRING.test(character)) {
                    cursorPosition++;
                    break;
                }

                textString += character;
                cursorPosition++;
                character = lenguajeContent[cursorPosition];
            }

            if (!STRING.test(character) && cursorPosition >= lenguajeContent.length) {
                throw new Error('Cadena sin comilla de cierre');
            }

            if (returned) {
                return { type: 'string', value: textString }
            } else {
                tokens.push({ type: 'string', value: textString });
                continue;
            }
        }

        // Si llegamos aquí, significa que no reconocimos el carácter
        throw new TypeError("I don't know what this character is: " + character);
    }

    return tokens;
}
