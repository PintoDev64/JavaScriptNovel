{
    "exclude": [
        "../../node_modules/**",
        "dist"
    ],
    "include": [
        "src"
    ],
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES6",
        "moduleResolution": "node",
        "rootDir": "./src",
        "baseUrl": "./",
        "outDir": "./dist",
        "declaration": true,
        "declarationDir": "./dist/types",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "noImplicitAny": true,
        "strictNullChecks": true
    },
}